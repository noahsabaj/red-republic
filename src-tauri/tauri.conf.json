{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Red Republic",
  "version": "../package.json",
  "identifier": "com.noahsabaj.redrepublic",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Red Republic",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "publisher": "Noah Sabaj",
    "shortDescription": "Planned-economy city builder",
    "longDescription": "Red Republic is an isometric planned-economy city builder: industry chains, housing, deterministic weather, and physical cross-border trade.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDRDM3RjQyNUE0RjhGNDQKUldSRWowOWFRbi9Udk9EQXJiYVh1TjZzUzVUczk4c3UzV05wdUVzWG4yOXZiV2d6SlZRaVl5YlEK",
      "endpoints": [
        "https://github.com/noahsabaj/red-republic/releases/latest/download/latest.json"
      ],
      "windows": { "installMode": "passive" }
    }
  }
}
